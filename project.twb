              <calculation class='tableau' formula='(SUM([renewables_electricity]) &#13;&#10;- LOOKUP(SUM([renewables_electricity]), -1))&#13;&#10;/&#13;&#10;ABS(LOOKUP(SUM([renewables_electricity]), -1))&#13;&#10;* 100'>
